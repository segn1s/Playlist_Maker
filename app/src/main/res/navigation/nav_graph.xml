<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/mediaFragment">

    <fragment
        android:id="@+id/searchFragment"
        android:name="org.segn1s.playlistmaker.presentation.search.SearchFragment"
        android:label="fragment_search"
        tools:layout="@layout/fragment_search" />

    <fragment
        android:id="@+id/mediaFragment"
        android:name="org.segn1s.playlistmaker.presentation.media.MediaFragment"
        android:label="fragment_library"
        tools:layout="@layout/fragment_media">

        <action
            android:id="@+id/action_mediaFragment_to_createPlaylistFragment"
            app:destination="@id/createPlaylistFragment" />

        <action
            android:id="@+id/action_mediaFragment_to_playlistWithTracksFragment"
            app:destination="@id/playlistWithTracksFragment" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="org.segn1s.playlistmaker.presentation.settings.SettingsFragment"
        android:label="fragment_settings"
        tools:layout="@layout/fragment_settings" />

    <fragment
        android:id="@+id/playerFragment"
        android:name="org.segn1s.playlistmaker.ui.player.PlayerFragment"
        android:label="PlayerFragment"
        tools:layout="@layout/fragment_player">

        <argument
            android:name="track"
            app:argType="org.segn1s.playlistmaker.domain.model.Track" />

        <action
            android:id="@+id/action_playerFragment_to_createPlaylistFragment"
            app:destination="@id/createPlaylistFragment" />
    </fragment>

    <fragment
        android:id="@+id/createPlaylistFragment"
        android:name="org.segn1s.playlistmaker.presentation.media.playlists.creating.CreatePlaylistFragment"
        android:label="CreatePlaylistFragment"
        tools:layout="@layout/fragment_create_playlist" />

    <fragment
        android:id="@+id/playlistWithTracksFragment"
        android:name="org.segn1s.playlistmaker.presentation.media.playlists.PlaylistWithTracksFragment"
        android:label="PlaylistWithTracksFragment"
        tools:layout="@layout/fragment_playlist_with_tracks">

        <argument
            android:name="playlistId"
            app:argType="integer" />

        <action
            android:id="@+id/action_playlistWithTracksFragment_to_playerFragment"
            app:destination="@id/playerFragment" />

        <action
            android:id="@+id/action_playlistWithTracksFragment_to_createPlaylistFragment"
            app:destination="@id/createPlaylistFragment" />
        <action
            android:id="@+id/action_playlistWithTracksFragment_to_editPlaylistFragment"
            app:destination="@id/editPlaylistFragment"/>
    </fragment>

    <fragment
        android:id="@+id/editPlaylistFragment"
        android:name="org.segn1s.playlistmaker.presentation.playlist_with_tracks.edit_playlist.EditPlaylistFragment"
        android:label="EditPlaylistFragment"
        tools:layout="@layout/fragment_create_playlist">

        <argument
            android:name="playlist"
            app:argType="org.segn1s.playlistmaker.domain.model.Playlist"/>

        <action
            android:id="@+id/action_editPlaylistFragment_to_playlistWithTracksFragment"
            app:destination="@id/playlistWithTracksFragment"/>
    </fragment>

</navigation>