<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical">

    <!-- Верхняя панель -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/backButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/arrow_left"
            app:tint="@color/onBackground"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Новый плейлист"
            android:textSize="24sp"
            android:textColor="@color/onBackground"
            android:fontFamily="@font/ys_display_medium"/>
    </LinearLayout>

    <!-- Обложка -->
    <FrameLayout
        android:id="@+id/coverContainer"
        android:layout_width="match_parent"
        android:layout_height="324dp"
        android:layout_marginTop="24dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:clipToOutline="true"
        android:outlineProvider="background"
        android:background="@drawable/playlist_cover_border">

        <ImageView
            android:id="@+id/addIcon"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_add_photo"
            android:layout_gravity="center"
            android:background="@drawable/playlist_cover_background"/>
    </FrameLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/playlistNameLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:hint="Название*"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxCornerRadiusTopStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusBottomEnd="8dp"
        app:boxStrokeColor="@color/backgroundPlaylistFragment"
        app:hintTextColor="@color/backgroundPlaylistFragment">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/playlistName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/ys_text"
            android:textColor="@color/onBackground"/>

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/playlistDescriptionLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:hint="Описание"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxCornerRadiusTopStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusBottomEnd="8dp"
        app:boxStrokeColor="@color/backgroundPlaylistFragment"
        app:hintTextColor="@color/backgroundPlaylistFragment">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/playlistDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/ys_text"
            android:textColor="@color/onBackground"/>

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Кнопка создать -->
    <Button
        android:id="@+id/createButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="104dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:cornerRadius="8dp"
        android:text="Создать"
        android:fontFamily="@font/ys_display"
        android:backgroundTint="@color/ic_create_playlist_button"
        android:textColor="@color/white"
        android:textAllCaps="false"
        android:enabled="false"/>

</LinearLayout>